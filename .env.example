# Public client config (safe to expose — anon key is protected by RLS)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# NOTE: VITE_TWELVE_DATA_API_KEY is intentionally NOT here.
# A VITE_ var is inlined into the browser bundle and therefore public.
# The TwelveData key must be rotated and kept server-side (edge functions).
